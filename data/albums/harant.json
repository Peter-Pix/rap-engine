  "quotes": [
    {
      "quote": "Harant je jako temná ulice v Liberci – když se do toho ponoříš, už nechceš ven.",
      "author": "Paulie Garand"
    },
    {
      "quote": "Paulie Garand je jedním z mála rapperů, kteří dokážou spojit literární kvalitu s pouličním feelingem.",
      "author": "Hip-Hop.cz"
    }
  ],
  "faq": [
    {
      "question": "Proč se album jmenuje Harant?",
      "answer": "Název odkazuje na Kryštofa Haranta z Polžic a Bezdružic, českého renesančního šlechtice, cestovatele a spisovatele. Paulie Garand tím chtěl vyjádřit svou vlastní cestu od ulic k umění a zároveň vzdát hold historické postavě, která spojuje intelekt a akci."
    },
    {
      "question": "Kdo produkoval album Harant?",
      "answer": "Hlavním producentem byl Paulie Garand sám, spolupracoval ale i s DJ Wichem, který se postaral o několik beatů. Zvukově je album mixem temných, minimalistických beatů s prvky boom bapu."
    },
    {
      "question": "Jaké jsou nejznámější tracky z alba?",
      "answer": "Mezi nejznámější tracky patří „Liberec“ (hymna města), „Nejsme nic“ (feat. Lipo, Eki) a „Hood“ (feat. Rest, Roseck). Všechny tyto skladby se staly klasikami českého underground-rapu."
    }
  ],
