  "faq": [
    {
      "question": "Proč se album jmenuje F4R4on?",
      "answer": "Název odkazuje na egyptského faraona a symbolizuje Lvcas Dopeho spojení s egyptskou kulturou a mytologií, které prostupuje celým albem."
    },
    {
      "question": "Kdo jsou hlavní hosté na albu?",
      "answer": "Na albu se objevují Ben Cristovao a Egem, kteří společně s Lvcas Dopeem nahráli skladbu Mamba."
    }
  ],
