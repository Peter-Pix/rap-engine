  "quotes": [
    {
      "quote": "Gudlak je album, které ukázalo, že český rap nemusí být jen o parodování Ameriky. Je to manifest generace, která chce být slyšet.",
      "source": "Hip-Hop.cz"
    },
    {
      "quote": "Yzomandias a Karlo na Gudlakovi vytvořili něco, co v českém rapovém undergroundu do té doby nebylo – temný, hypnotický zvuk s texty, které rezonují.",
      "source": "Bandzone.cz"
    }
  ],
  "faq": [
    {
      "question": "Proč se album jmenuje [Gudlak]?",
      "answer": "Název odkazuje na slovenské slovo „gudlak“, což je hovorový výraz pro člověka, který se snaží být víc, než ve skutečnosti je. Yzomandias a Karlo tím chtěli vyjádřit svou touhu prorazit a ukázat světu, co umí – i když to znamená hrát si na někoho většího, než jsou."
    },
    {
      "question": "Kdo produkoval album [Gudlak]?",
      "answer": "Hlavními producenty alba byli Konex a Pil C, kteří se postarali o temné, hypnotické beaty, jež se staly charakteristickým zvukem projektu."
    },
    {
      "question": "Jaký je vztah mezi [Gudlak]em a albem Palác od Barbera?",
      "answer": "Oba projekty vyšly v roce 2016 a jsou spojeny s labelem Milion+. Zatímco [Gudlak] je debutem Yzomandiase a Karla, Palác je sólovým albem Barbera, dalšího člena Milion+. Oba projekty pomohly definovat zvuk českého trapu té doby."
    }
  ],
